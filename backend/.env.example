# ─── AgriSmart Backend Configuration ───
# Copy this file to .env and fill in the required values.

# ─── MongoDB ───
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=agrismart

# ─── JWT Auth ───
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Groq API Key (required for AI Chat Assistant — 100% FREE) ───
# Get your free key at: https://console.groq.com/keys
# Models: llama-3.3-70b-versatile (text) + llama-3.2-11b-vision (images)
# Free tier: 14,400 req/day, no credit card required
GROQ_API_KEY=gsk_...

# ─── Weather API Key (NOT REQUIRED — now using Open-Meteo, FREE) ───
# Open-Meteo API is completely free and requires no API key.
# https://open-meteo.com/
# WEATHER_API_KEY is OPTIONAL and no longer used.
WEATHER_API_KEY=

# ─── Government Data API (optional, for market prices) ───
# Get from: https://data.gov.in/
DATA_GOV_API_KEY=

# ─── App Config ───
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
